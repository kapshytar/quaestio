<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mergeScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/configContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/merge_provider"
                android:textColor="@color/text_primary" />

            <Spinner
                android:id="@+id/providerSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <!-- API Key Source Selection (for testing) -->
            <RadioGroup
                android:id="@+id/apiKeySourceGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbPreinstalledKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Use Preinstalled Key"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/rbCustomKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enter Custom Key"
                    android:textColor="@color/text_primary" />
            </RadioGroup>

            <!-- API Key Input (hidden when preinstalled is selected) -->
            <EditText
                android:id="@+id/apiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/merge_api_key_hint"
                android:importantForAutofill="no"
                android:inputType="textNoSuggestions|textVisiblePassword"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:visibility="gone" />

            <EditText
                android:id="@+id/customEndpointInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/merge_custom_endpoint_hint"
                android:importantForAutofill="no"
                android:inputType="textUri"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:visibility="gone" />

            <EditText
                android:id="@+id/customModelInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/merge_custom_model_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:visibility="gone" />

            <EditText
                android:id="@+id/fallbackModelsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="@string/merge_fallback_models_hint"
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:minLines="3"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHideConfig"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:text="Hide Config"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/configCollapsedHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/merge_collapsed_hint"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/aggregationControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshAggregation"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:text="Refresh statuses" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPauseAggregation"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:text="Pause aggregation" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCollectNow"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:text="Collect now" />
            </LinearLayout>

            <TextView
                android:id="@+id/aggregationStatusSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Slot aggregation idle"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/debugLogContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Verbose merge log"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearDebugLog"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:text="Clear" />
                </LinearLayout>

                <TextView
                    android:id="@+id/debugLogText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="monospace"
                    android:text="No activity yet..."
                    android:textColor="@color/text_primary"
                    android:textIsSelectable="true"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Minimalist Tonal result without heavy cards -->
        <TextView
            android:id="@+id/mergeResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:text="@string/merge_idle_text"
            android:textColor="@color/text_primary"
            android:textIsSelectable="true" />

        <LinearLayout
            android:id="@+id/clarificationInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/clarificationInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="need clarification?"
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendClarification"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Send"
                app:icon="@drawable/ic_action_send"
                app:iconTint="@android:color/white"
                app:backgroundTint="@color/action_primary"
                app:iconSize="24dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
